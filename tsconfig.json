{
  "compilerOptions": {
    "target": "ES2020",
    "module": "None",
    "ignoreDeprecations": "6.0",
    "lib": ["DOM", "ES2020"],
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true
  },
  "include": ["src/**/*.ts"]
}
