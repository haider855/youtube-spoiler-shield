{
  "manifest_version": 3,
  "name": "YouTube Spoiler Shield",
  "version": "0.1.0",
  "description": "Blur YouTube videos and recommendations that match your spoiler keywords.",
  "icons": {
    "16": "src/assets/icons/icon16.png",
    "32": "src/assets/icons/icon32.png",
    "48": "src/assets/icons/icon48.png",
    "128": "src/assets/icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_title": "YouTube Spoiler Shield",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "src/assets/icons/icon16.png",
      "32": "src/assets/icons/icon32.png",
      "48": "src/assets/icons/icon48.png",
      "128": "src/assets/icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": [
        "dist/shared/constants.js",
        "dist/shared/matching.js",
        "dist/shared/storage.js",
        "dist/content/youtubeCards.js",
        "dist/content/blocker.js",
        "dist/content/observer.js",
        "dist/content/content.js"
      ],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    }
  ]
}
